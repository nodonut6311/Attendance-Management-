	reports
	{
		list employees_Report
		{
			displayName = "All Employees"
			show all rows from employees    
			(
				employee_id as "Employee ID"
				first_name1 as "First Name"
				last_name1 as "Last Name"
				email as "Email"
				department as "Department"
				designation as "Designation"
				date_of_joining as "Date of Joining"
				work_phone as "Work Phone"
				seating_location as "Seating Location"
			)
		}
		list attendance_records_Report
		{
			displayName = "All Attendance Records"
			show all rows from attendance_records    
			(
				record_id as "Record ID"
				employee as "Employee"
				date_1 as "Date"
				check_in as "Check In"
				check_out as "Check Out"
				status as "Status"
				is_approved as "Is Approved"
				notes as "Notes"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (status == "Absent")
				fields = [status]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (status == "Court Appearance")
				fields = [status]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"New Formatting3"
				{
				condition = (status == "Present")
				fields = [status]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
			)
		}
		kanban attendance_records_by_status
		{
			displayName = "Statuses"
			show all rows from attendance_records    
			(
				record_id as "Record ID"
				employee as "Employee"
				date_1 as "Date"
				check_in as "Check In"
				check_out as "Check Out"
				status as "Status"
				is_approved as "Is Approved"
				notes as "Notes"
			)
			options
			(
	 			display field = status
	 		)
		}
		list attendance_exceptions_Report
		{
			displayName = "All Attendance Exceptions"
			show all rows from attendance_exceptions    
			(
				employee as "Employee"
				record as "Attendance Record"
				exception_type as "Exception Type"
				description as "Description"
				reported_date as "Reported Date"
				resolved as "Resolved"
				resolved_by as "Resolved By"
				resolution_notes as "Resolution Notes"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (exception_type == "Early Departure")
				fields = [exception_type]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (exception_type == "Late Arrival")
				fields = [exception_type]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"New Formatting3"
				{
				condition = (exception_type == "Missed Check-In")
				fields = [exception_type]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
				"New Formatting4"
				{
				condition = (exception_type == "Unapproved Absence")
				fields = [exception_type]
				format = "color:#ffffff;background-color:#3598db;"
				}
			)
		}
		kanban attendance_exceptions_by_exception_type
		{
			displayName = "Exception Types"
