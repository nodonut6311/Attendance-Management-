 application "Attendance Management"
 {
 	date format = "dd-MMM-yyyy"
 	time zone = "America/Los_Angeles"
 	time format = "24-hr"
 	forms
	{
		form attendance_exceptions
		{
			displayname = "Attendance Exceptions"
			success message = "Attendance Exception Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			employee
			(
				type = list	
				displayname = "Employee"
				values  = employees.ID
    			displayformat = [employee_id]
				allow new entries
				[
					displayname = "Add New"
				]
				sortorder = ascending
				height = 13px
	 			row = 1
	 			column = 1   
				width = medium
			)
			record
			(
				type = list	
				displayname = "Attendance Record"
				values  = attendance_records.ID
    			displayformat = [record_id]
				allow new entries
				[
					displayname = "Add New"
				]
				sortorder = ascending
				height = 13px
	 			row = 1
	 			column = 1   
				width = medium
			)
			exception_type
			(
				type = picklist
				displayname = "Exception Type"
				values = {"Unapproved Absence","Missed Check-In","Late Arrival","Early Departure"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			description
			(
    			type = textarea
				displayname = "Description"
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
			reported_date
			(
    			type = datetime
				displayname = "Reported Date"
				timedisplayoptions = "hh:mm:ss"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			resolved
			(
    			type = checkbox
				displayname = "Resolved"
				initial value = false
	 			row = 1
	 			column = 1   
				width = medium
			)
			resolved_by
			(
    			type = text
				displayname = "Resolved By"
	 			row = 1
	 			column = 1   
				width = medium
			)
			resolution_notes
			(
    			type = textarea
				displayname = "Resolution Notes"
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
			blueprint components
			{
				stages = {"Exception Reported","Exception Under Review","Exception Escalated","Exception Resolved","Exception Rejected","Exception Closed"}
			}
		}
